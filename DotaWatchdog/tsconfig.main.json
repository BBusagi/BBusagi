{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist/main",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/core/**/*",
    "src/blocker/**/*",
    "src/cooldown/**/*",
    "src/challenge/**/*",
    "src/ai/**/*"
  ],
  "exclude": ["node_modules", "dist", "src/ui/**/*"]
}
